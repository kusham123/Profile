{
  "name": "newprot-monorepo",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "apps/services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@apps/web",
    "build": "npm run build --workspace=@apps/web",
